{
  "name": "virens",
  "version": "1.0.0",
  "private": true,
  "description": "Virens — Creator-centric visual discovery platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "dev:web": "pnpm --filter @virens/web dev",
    "dev:api": "pnpm --filter @virens/api dev",
    "build:web": "pnpm --filter @virens/web build",
    "build:all": "turbo run build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
