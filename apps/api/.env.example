# ── App ─────────────────────────────────────────────
APP_NAME=Virens
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALLOWED_ORIGINS=["http://localhost:3000","https://virens.app"]

# ── MongoDB ──────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=virens

# ── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Paystack (Primary) ───────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# ── Stripe (Secondary) ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ── Groq AI ──────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter (fallback) ────────────────────────────
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxx

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Platform settings ────────────────────────────────
MINIMUM_PAYOUT_NGN=10000
SUBSCRIPTION_BASIC_NGN=1500
SUBSCRIPTION_PRO_NGN=4500
SUBSCRIPTION_CREATOR_SUPPORT_NGN=9000
AD_MIN_BUDGET_NGN=5000
AD_MAX_BUDGET_NGN=50000
